# backend/dockerfile — CPU-сборка бэкенда и рантайма LLM (llama-cpp-python >=0.3).
# Грузит ЛЮБУЮ современную GGUF-архитектуру. GPU/CUDA-вариант — backend/dockerfile.cuda
# (+ docker-compose.gpu.yml). Переключение модели рестартом НЕ требует пересборки образа.
FROM python:3.11-slim

# Системные зависимости: libpq (psycopg), curl (healthcheck), build-essential+cmake —
# на случай, если для llama-cpp-python нет готового wheel и нужна сборка из исходников.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev curl build-essential cmake \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 appuser
WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
RUN pip install --no-cache-dir -e .

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
