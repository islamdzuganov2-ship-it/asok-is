# backend/dockerfile — CPU-сборка бэкенда и рантайма LLM (llama-cpp-python >=0.3).
# Грузит ЛЮБУЮ современную GGUF-архитектуру. GPU/CUDA-вариант — backend/dockerfile.cuda
# (+ docker-compose.gpu.yml). Переключение модели рестартом НЕ требует пересборки образа.
FROM python:3.11-slim

# Системные зависимости: libpq (psycopg), curl (healthcheck) и musl.
# ГОТОВОЕ CPU-колесо llama-cpp-python с индекса abetlen слинковано с musl-libc (Alpine). Чтобы
# оно грузилось на Debian/glibc БЕЗ компиляции (сборка llama.cpp из исходников не помещается в
# память — OOM), ставим пакет musl и даём его libc под ожидаемым колесом именем.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev curl musl libgomp1 \
    && ln -sf /lib/ld-musl-x86_64.so.1 /lib/libc.musl-x86_64.so.1 \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 appuser
WORKDIR /app

COPY requirements.txt ./
# --only-binary=llama-cpp-python → строго готовое колесо (никакой компиляции/OOM); версия в
# requirements подобрана так, чтобы колесо на индексе существовало (см. комментарий там).
RUN pip install --no-cache-dir \
    --only-binary=llama-cpp-python \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu \
    -r requirements.txt

COPY . .
RUN pip install --no-cache-dir -e .

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
