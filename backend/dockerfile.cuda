# backend/dockerfile.cuda — GPU/CUDA-сборка рантайма LLM (llama-cpp-python с offload на GPU).
# Для практичной работы крупных моделей (7B–14B, напр. Qwen3 14B из целевой схемы).
#
# Требуется: NVIDIA GPU + драйвер + nvidia-container-toolkit (на Windows — через WSL2).
# Запуск:  docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d --build
#
# База -devel (есть nvcc) — чтобы сработал и путь готового CUDA-колеса, и сборка из sdist.
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
# CMAKE_ARGS включает CUDA-бэкенд, если llama-cpp-python собирается из исходников (нет колеса).
ENV CMAKE_ARGS="-DGGML_CUDA=on"
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev libpq-dev curl build-essential cmake \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 appuser
WORKDIR /app

COPY requirements.txt ./
# Готовые GPU-колёса llama-cpp-python (CUDA 12.4) — с индекса abetlen; при отсутствии колеса
# для закреплённой версии pip соберёт из sdist с CMAKE_ARGS выше (nvcc есть в -devel базе).
RUN pip install --no-cache-dir \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124 \
    -r requirements.txt

COPY . .
RUN pip install --no-cache-dir -e .

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
