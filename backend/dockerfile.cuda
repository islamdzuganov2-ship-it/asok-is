# backend/dockerfile.cuda — GPU/CUDA-сборка рантайма LLM (llama-cpp-python с offload на GPU).
# Для практичной работы крупных моделей (7B–14B, напр. Qwen3 14B из целевой схемы).
#
# Требуется: NVIDIA GPU + драйвер + nvidia-container-toolkit (на Windows — через WSL2).
# Запуск:  docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d --build
#
# База -devel (есть nvcc) — чтобы сработал и путь готового CUDA-колеса, и сборка из sdist.
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
# Собираем llama-cpp-python ИЗ ИСХОДНИКОВ с CUDA-бэкендом (готовые колёса abetlen слинкованы с
# musl и конфликтуют с glibc-библиотеками CUDA). На GPU-хосте памяти под компиляцию достаточно.
ENV CMAKE_ARGS="-DGGML_CUDA=on"
ENV FORCE_CMAKE=1
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev libpq-dev curl build-essential cmake git \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 appuser
WORKDIR /app

COPY requirements.txt ./
# llama-cpp-python компилируется из sdist с CUDA (CMAKE_ARGS выше); прочие пакеты — обычные колёса.
RUN pip install --no-cache-dir --no-binary=llama-cpp-python -r requirements.txt

COPY . .
RUN pip install --no-cache-dir -e .

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
