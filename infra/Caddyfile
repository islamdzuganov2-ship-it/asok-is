# Прямой веб-сервер вашего ПК для домена asokis.ai (без туннеля/прокси в трафике).
# Caddy сам получает бесплатный TLS-сертификат Let's Encrypt (HTTP-01), поэтому
# обязателен реальный доступ из интернета к портам 80 и 443 этого ПК
# и A-запись asokis.ai → ваш публичный IP в режиме DNS-only (серое облако Cloudflare).

asokis.ai, www.asokis.ai {
    encode zstd gzip
    # Весь трафик → фронтенд (Vite), который сам проксирует /api на бэкенд.
    reverse_proxy frontend:3000
}
