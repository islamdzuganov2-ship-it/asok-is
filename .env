# === БАЗА ДАННЫХ ===
POSTGRES_DB=asok_is
POSTGRES_USER=asok_user
POSTGRES_PASSWORD=asok_secure_password_123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://asok_user:asok_secure_password_123@postgres:5432/asok_is

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === JWT SECURITY ===
JWT_SECRET=dev_jwt_secret_change_in_production_minimum_32_chars_long!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === APP SETTINGS ===
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# === FEATURE FLAGS ===
FEATURE_LDAP_AUTH=false
FEATURE_JIRA_INTEGRATION=false
FEATURE_AI_SUMMARY=false
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=asok-model:latest
LOCAL_LLM_MODEL_DIR=models/llm
LOCAL_LLM_MODEL_FILE=asok-model.gguf
DEMO_MODE=true

# === DEMO USERS (только для development) ===
DEMO_USER_ANALYST=demo_analyst:Analyst123!:TEST_ANALYST
DEMO_USER_MANAGER=demo_manager:Manager123!:QUALITY_MANAGER
DEMO_USER_ADMIN=admin:Admin123!:ADMIN


