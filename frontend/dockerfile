# === Этап 1: Сборка приложения (Builder) ===
FROM node:20-alpine as builder

WORKDIR /app

# Копируем package.json и устанавливаем зависимости
COPY package*.json ./
RUN npm install

# Копируем весь исходный код и запускаем сборку Vite
COPY . .
RUN npm run build

# === Этап 2: Раздача статики через Nginx (Runtime) ===
FROM nginx:1.25-alpine

# Копируем конфигурацию Nginx (если она есть у вас в проекте)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# ВАЖНО: Vite по умолчанию собирает билд в папку dist, а не build
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]